%%[
SET @action        = RequestParameter('action')
SET @bu            = RequestParameter('bu')
SET @nl            = Char(10)
SET @cr            = Char(13)
SET @result        = ''
SET @ANTHROPIC_KEY = 'YOUR_ANTHROPIC_KEY_HERE'

IF Empty(@bu) THEN
  SET @bu = 'finclass'
ENDIF

/* ---- PING ---- */
IF @action == 'ping' THEN

  SET @result = '{"success":true,"message":"MKTC API ok"}'

/* ---- LIST TEMPLATES ---- */
ELSEIF @action == 'list_templates' THEN

  SET @result = '{"success":true,"data":[{"id":"full-hero","name":"Hero Completo"},{"id":"text-first","name":"Copy Longa"},{"id":"side-image","name":"Imagem Lateral"},{"id":"multi-block","name":"Multi-bloco"},{"id":"minimal","name":"Minimal"},{"id":"announcement","name":"Anuncio"}]}'

/* ---- GET STATS ---- */
ELSEIF @action == 'get_stats' THEN

  SET @statsRows = LookupRows('MKTC_Emails', 'BU', @bu)
  SET @statsCnt  = RowCount(@statsRows)
  SET @nRascunho = 0
  SET @nEmAp     = 0
  SET @nAprov    = 0
  SET @nAgend    = 0
  SET @nEnv      = 0

  FOR @si = 1 TO @statsCnt DO
    SET @sRow = Row(@statsRows, @si)
    SET @sVal = Field(@sRow, 'Status')
    IF @sVal == 'rascunho'     THEN SET @nRascunho = ADD(@nRascunho,1) ENDIF
    IF @sVal == 'em_aprovacao' THEN SET @nEmAp     = ADD(@nEmAp,1)     ENDIF
    IF @sVal == 'aprovado'     THEN SET @nAprov    = ADD(@nAprov,1)    ENDIF
    IF @sVal == 'agendado'     THEN SET @nAgend    = ADD(@nAgend,1)    ENDIF
    IF @sVal == 'enviado'      THEN SET @nEnv      = ADD(@nEnv,1)      ENDIF
  NEXT @si

  SET @result = Concat(
    '{"success":true,"data":{"total":',@statsCnt,
    ',"rascunho":',@nRascunho,
    ',"em_aprovacao":',@nEmAp,
    ',"aprovado":',@nAprov,
    ',"agendado":',@nAgend,
    ',"enviado":',@nEnv,'}}')

/* ---- GET DATAVIEWS ---- */
ELSEIF @action == 'get_dataviews' THEN

  SET @dvDays = RequestParameter('days')
  IF Empty(@dvDays) THEN SET @dvDays = 30 ENDIF

  SET @dvCutoff = DateAdd(Now(), Subtract(0, @dvDays), 'D')

  SET @dvRows = LookupRows('MKTC_Dashboard_Daily', 'BU', @bu)
  SET @dvCnt  = RowCount(@dvRows)

  SET @dvSent   = 0
  SET @dvDeliv  = 0
  SET @dvOpens  = 0
  SET @dvClicks = 0
  SET @dvBounce = 0
  SET @dvUnsub  = 0

  FOR @di = 1 TO @dvCnt DO
    SET @dRow  = Row(@dvRows, @di)
    SET @dDate = Field(@dRow, 'Date')
    IF DateDiff(@dvCutoff, @dDate, 'D') >= 0 THEN
      SET @dvSent   = Add(@dvSent,   Field(@dRow, 'Sent'))
      SET @dvDeliv  = Add(@dvDeliv,  Field(@dRow, 'Delivered'))
      SET @dvOpens  = Add(@dvOpens,  Field(@dRow, 'UniqueOpens'))
      SET @dvClicks = Add(@dvClicks, Field(@dRow, 'UniqueClicks'))
      SET @dvBounce = Add(@dvBounce, Field(@dRow, 'Bounces'))
      SET @dvUnsub  = Add(@dvUnsub,  Field(@dRow, 'Unsubscribes'))
    ENDIF
  NEXT @di

  SET @result = Concat(
    '{"success":true,"data":{',
    '"sends":',         @dvSent,
    ',"delivered":',    @dvDeliv,
    ',"opens":',        @dvOpens,
    ',"clicks":',       @dvClicks,
    ',"bounces":',      @dvBounce,
    ',"unsubscribes":', @dvUnsub,
    '},"debug":{"rowCount":', @dvCnt, ',"bu":"', @bu, '"}}')

/* ---- ANALYZE JOURNEY ---- */
ELSEIF @action == 'analyze_journey' THEN

  SET @jName     = RequestParameter('name')
  SET @jBriefing = RequestParameter('briefing')
  SET @jImage    = RequestParameter('image')

  SET @jSys = 'Você é um especialista em jornadas de email marketing. Analise o mapa de jornada e o briefing. Retorne APENAS um JSON minificado válido, sem markdown, sem texto extra.'

  SET @jTxt = Concat(
    'Jornada: ', @jName, '\nBU/Marca: ', @bu,
    '\n\nBriefing:\n', @jBriefing,
    '\n\nRetorne APENAS este JSON (sem markdown, sem explicação):',
    '{"name":"...","description":"...","entryEvent":"...",',
    '"steps":[{"id":1,"name":"...","delay":0,"delayUnit":"days",',
    '"subject":"...","preheader":"...","copyText":"copy completa do email","template":"full-hero"}]}',
    '\nTemplates disponíveis: full-hero, text-first, side-image, multi-block, minimal, announcement',
    '\nRegras: delay=0 no primeiro step; delays seguintes em dias desde o email anterior.',
    '\nGere a copy completa de cada email no campo copyText.')

  SET @jTxtE = Replace(Replace(Replace(Replace(@jTxt,'\','\\'),'"','\"'),Char(10),'\n'),Char(13),'\r')
  SET @jSysE = Replace(Replace(@jSys,'\','\\'),'"','\"')

  IF NOT Empty(@jImage) THEN
    SET @jPayload = Concat(
      '{"model":"claude-haiku-4-5-20251001","max_tokens":4000,',
      '"system":"', @jSysE, '",',
      '"messages":[{"role":"user","content":[',
      '{"type":"image","source":{"type":"base64","media_type":"image/png","data":"', @jImage, '"}},',
      '{"type":"text","text":"', @jTxtE, '"}',
      ']}]}')
  ELSE
    SET @jPayload = Concat(
      '{"model":"claude-haiku-4-5-20251001","max_tokens":4000,',
      '"system":"', @jSysE, '",',
      '"messages":[{"role":"user","content":"', @jTxtE, '"}]}')
  ENDIF

  SET @jHdrNames  = 'x-api-key,anthropic-version'
  SET @jHdrValues = Concat(@ANTHROPIC_KEY, ',2023-06-01')

  SET @jResp = HTTPPost2(
    'https://api.anthropic.com/v1/messages',
    'application/json',
    @jPayload,
    @jHdrNames, @jHdrValues,
    @jStatus)

  IF @jStatus == 200 THEN
    SET @result = Concat('{"success":true,"raw":', @jResp, '}')
  ELSE
    SET @result = Concat('{"success":false,"error":"Anthropic HTTP ', @jStatus, '"}')
  ENDIF

/* ---- LIST EMAILS ---- */
ELSEIF @action == 'list_emails' THEN

  SET @filterSt = RequestParameter('status')
  SET @listRows = LookupOrderedRows('MKTC_Emails', 500, 'Updated_Date DESC', 'BU', @bu)
  SET @listCnt  = RowCount(@listRows)
  SET @listJson = '{"success":true,"data":['
  SET @listSep  = ''

  FOR @li = 1 TO @listCnt DO
    SET @lRow = Row(@listRows, @li)
    SET @lSt  = Field(@lRow, 'Status')

    IF Empty(@filterSt) OR @filterSt == 'all' OR @lSt == @filterSt THEN
      SET @lNome = Replace(Replace(Replace(Field(@lRow,'Nome'),'\','\\'),'"','\"'),@nl,'\n')
      SET @lAssu = Replace(Replace(Replace(Field(@lRow,'Assunto'),'\','\\'),'"','\"'),@nl,'\n')
      SET @lPre  = Replace(Replace(Replace(Field(@lRow,'Preheader'),'\','\\'),'"','\"'),@nl,'\n')
      SET @lObs  = Replace(Replace(Replace(Field(@lRow,'Obs'),'\','\\'),'"','\"'),@nl,'\n')
      SET @lDeE  = Replace(Replace(Field(@lRow,'DE_Envio'),'\','\\'),'"','\"')
      SET @lDeX  = Replace(Replace(Field(@lRow,'DE_Exclusao'),'\','\\'),'"','\"')

      SET @listJson = Concat(@listJson, @listSep,
        '{"ID":"',          Field(@lRow,'ID'),          '"',
        ',"BU":"',          @bu,                        '"',
        ',"Nome":"',        @lNome,                     '"',
        ',"Status":"',      @lSt,                       '"',
        ',"Assunto":"',     @lAssu,                     '"',
        ',"Preheader":"',   @lPre,                      '"',
        ',"Template_ID":"', Field(@lRow,'Template_ID'), '"',
        ',"Send_Date":"',   Field(@lRow,'Send_Date'),   '"',
        ',"Send_Time":"',   Field(@lRow,'Send_Time'),   '"',
        ',"DE_Envio":"',    @lDeE,                      '"',
        ',"DE_Exclusao":"', @lDeX,                      '"',
        ',"Obs":"',         @lObs,                      '"',
        ',"Updated_Date":"',Field(@lRow,'Updated_Date'),'"',
        ',"Created_Date":"',Field(@lRow,'Created_Date'),'"',
        ',"HTML_Content":""',
        '}')
      SET @listSep = ','
    ENDIF
  NEXT @li

  SET @result = Concat(@listJson, ']}')

/* ---- GET EMAIL ---- */
ELSEIF @action == 'get_email' THEN

  SET @geId   = RequestParameter('id')
  SET @geRows = LookupRows('MKTC_Emails', 'ID', @geId)

  IF RowCount(@geRows) == 0 THEN
    SET @result = '{"success":false,"error":"Email not found"}'
  ELSE
    SET @geRow  = Row(@geRows, 1)
    SET @geHtml = Field(@geRow, 'HTML_Content')
    SET @geHtml = Replace(@geHtml, '\',    '\\')
    SET @geHtml = Replace(@geHtml, '"',    '\"')
    SET @geHtml = Replace(@geHtml, @nl,    '\n')
    SET @geHtml = Replace(@geHtml, @cr,    '\r')
    SET @geHtml = Replace(@geHtml, Char(9),'\t')

    SET @geNome = Replace(Replace(Replace(Field(@geRow,'Nome'),'\','\\'),'"','\"'),@nl,'\n')
    SET @geAssu = Replace(Replace(Replace(Field(@geRow,'Assunto'),'\','\\'),'"','\"'),@nl,'\n')
    SET @gePre  = Replace(Replace(Replace(Field(@geRow,'Preheader'),'\','\\'),'"','\"'),@nl,'\n')
    SET @geObs  = Replace(Replace(Replace(Field(@geRow,'Obs'),'\','\\'),'"','\"'),@nl,'\n')
    SET @geDeE  = Replace(Replace(Field(@geRow,'DE_Envio'),'\','\\'),'"','\"')
    SET @geDeX  = Replace(Replace(Field(@geRow,'DE_Exclusao'),'\','\\'),'"','\"')

    SET @result = Concat(
      '{"success":true,"data":{',
      '"ID":"',           Field(@geRow,'ID'),          '"',
      ',"BU":"',          @bu,                         '"',
      ',"Nome":"',        @geNome,                     '"',
      ',"Status":"',      Field(@geRow,'Status'),      '"',
      ',"Assunto":"',     @geAssu,                     '"',
      ',"Preheader":"',   @gePre,                      '"',
      ',"Template_ID":"', Field(@geRow,'Template_ID'), '"',
      ',"Send_Date":"',   Field(@geRow,'Send_Date'),   '"',
      ',"Send_Time":"',   Field(@geRow,'Send_Time'),   '"',
      ',"DE_Envio":"',    @geDeE,                      '"',
      ',"DE_Exclusao":"', @geDeX,                      '"',
      ',"Obs":"',         @geObs,                      '"',
      ',"Updated_Date":"',Field(@geRow,'Updated_Date'),'"',
      ',"Created_Date":"',Field(@geRow,'Created_Date'),'"',
      ',"HTML_Content":"',@geHtml,                     '"',
      '}}')
  ENDIF

/* ---- SAVE EMAIL ---- */
ELSEIF @action == 'save_email' THEN

  SET @svId  = RequestParameter('ID')
  IF Empty(@svId) THEN SET @svId = GUID() ENDIF

  SET @svNome = RequestParameter('Nome')
  IF Empty(@svNome) THEN SET @svNome = 'Email sem nome' ENDIF

  SET @svSt = RequestParameter('Status')
  IF Empty(@svSt) THEN SET @svSt = 'rascunho' ENDIF

  SET @svTid = RequestParameter('Template_ID')
  IF Empty(@svTid) THEN SET @svTid = 'full-hero' ENDIF

  SET @svCheck = LookupRows('MKTC_Emails', 'ID', @svId)

  IF RowCount(@svCheck) > 0 THEN
    UpdateDE('MKTC_Emails', 1, 'ID', @svId,
      'BU',           @bu,
      'Nome',         @svNome,
      'Status',       @svSt,
      'Assunto',      RequestParameter('Assunto'),
      'Preheader',    RequestParameter('Preheader'),
      'Template_ID',  @svTid,
      'HTML_Content', RequestParameter('HTML_Content'),
      'Send_Date',    RequestParameter('Send_Date'),
      'Send_Time',    RequestParameter('Send_Time'),
      'DE_Envio',     RequestParameter('DE_Envio'),
      'DE_Exclusao',  RequestParameter('DE_Exclusao'),
      'Obs',          RequestParameter('Obs'),
      'Updated_Date', Now()
    )
  ELSE
    InsertDE('MKTC_Emails',
      'ID',           @svId,
      'BU',           @bu,
      'Nome',         @svNome,
      'Status',       @svSt,
      'Assunto',      RequestParameter('Assunto'),
      'Preheader',    RequestParameter('Preheader'),
      'Template_ID',  @svTid,
      'HTML_Content', RequestParameter('HTML_Content'),
      'Send_Date',    RequestParameter('Send_Date'),
      'Send_Time',    RequestParameter('Send_Time'),
      'DE_Envio',     RequestParameter('DE_Envio'),
      'DE_Exclusao',  RequestParameter('DE_Exclusao'),
      'Obs',          RequestParameter('Obs'),
      'Updated_Date', Now(),
      'Created_Date', Now()
    )
  ENDIF

  SET @result = Concat('{"success":true,"id":"', @svId, '"}')

/* ---- DELETE EMAIL ---- */
ELSEIF @action == 'delete_email' THEN

  SET @delId = RequestParameter('ID')
  IF Empty(@delId) THEN
    SET @result = '{"success":false,"error":"ID obrigatorio"}'
  ELSE
    DeleteDE('MKTC_Emails', 1, 'ID', @delId)
    SET @result = '{"success":true}'
  ENDIF

/* ---- GENERATE HTML ---- */
ELSEIF @action == 'generate_html' THEN

  SET @result = '{"success":false,"error":"Geracao de HTML por IA nao disponivel neste ambiente"}'

/* ---- UNKNOWN ---- */
ELSE

  SET @result = Concat('{"success":false,"error":"Unknown action: ', @action, '"}')

ENDIF

]%%
%%=v(@result)=%%
